# Flatnotes - Self-Hosted Note-Taking App
# https://github.com/dullage/flatnotes

# Timezone
TZ=America/New_York

# User/Group IDs
SERVICE_USER=1000
SERVICE_GROUP=1000

# App secret (min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Auth type: password, totp, or none
FLATNOTES_AUTH_TYPE=password

# Admin credentials
APP_ADMIN_USER=admin
APP_ADMIN_PASS=changeme_admin_password
